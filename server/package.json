  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "npm run prisma:generate && npm run build",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "dev:auth": "nodemon --watch src --ext ts --exec ts-node src/modules/auth/server.ts",
    "dev:patient": "nodemon --watch src --ext ts --exec ts-node src/modules/patient/server.ts",
    "dev:risk": "nodemon --watch src --ext ts --exec ts-node src/modules/risk/server.ts",
    "dev:monitoring": "nodemon --watch src --ext ts --exec ts-node src/modules/monitoring/server.ts",
    "dev:treatment": "nodemon --watch src --ext ts --exec ts-node src/modules/treatment/server.ts",
    "dev:notification": "nodemon --watch src --ext ts --exec ts-node src/modules/notification/server.ts",
    "dev:dashboard": "nodemon --watch src --ext ts --exec ts-node src/modules/dashboard/server.ts",
    "prisma:generate": "prisma generate",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:auth": "node dist/modules/auth/server.js",
    "start:patient": "node dist/modules/patient/server.js",
    "start:risk": "node dist/modules/risk/server.js",
    "start:monitoring": "node dist/modules/monitoring/server.js",
    "start:treatment": "node dist/modules/treatment/server.js",
    "start:notification": "node dist/modules/notification/server.js",
    "start:dashboard": "node dist/modules/dashboard/server.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
